

# Python virtual envs / builds / MLflow runs
.venv/
.venv*/
venv/
env/
.env
build/
dist/
mlruns/
model_dir/

# Caches
__pycache__/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# temporary files / local smoke outputs
*.log
*.tmp
.streamlit/
tmp/

# Data layers — actual data files are never committed; .gitkeep files preserve structure
data/raw/*
data/bronze/*
data/silver/*
data/gold/*
data/cache/*
!data/**/.gitkeep

# DuckDB warehouse files — large binaries, not committed
warehouse/*.duckdb*

# dbt
dbt/.user.yml
dbt/profiles.yml

# Airflow local runtime artifacts (keep dags/ in git, ignore runtime state)
airflow/logs/
airflow/airflow.db*
airflow/airflow.cfg
airflow/standalone_admin_password.txt
airflow/*.pid

# local planning attachments
plan/*


