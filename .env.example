# .env.example — copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is gitignored and must never be committed.
# .env.example is committed and documents every tuneable variable.
#
# All values here are the same defaults used by src/config/settings.py,
# so the pipeline runs out-of-the-box without a .env file on CI.

# ── Analysis scope ────────────────────────────────────────────────────────────
ANALYSIS_START_DATE=2026-02-01
ANALYSIS_END_DATE=2026-04-30

# Must be even (50/50 gender split for matched-pair analysis).
CANDIDATE_SAMPLE_SIZE=24

# ── Paths ─────────────────────────────────────────────────────────────────────
# Relative to the project root. Override only if you want data outside the repo.
DATA_DIR=data
WAREHOUSE_PATH=warehouse/municipal.duckdb

# ── GDELT ─────────────────────────────────────────────────────────────────────
# GDELT DOC 2.0 API hard cap: do not raise above 250.
GDELT_MAX_RECORDS=250

# Seconds to wait between GDELT requests — respectful rate limiting.
GDELT_REQUEST_DELAY_SECONDS=2

# Hybrid news discovery provider order for the main fast path.
# GDELT is intentionally excluded here because it is better run as a slower,
# separate backfill job.
NEWS_PROVIDER_ORDER=curated,gnews

# Benchmark provider order. Keep this aligned with the fast path unless you are
# explicitly running a source-comparison experiment.
NEWS_BENCHMARK_PROVIDER_ORDER=curated,gnews

# Optional Tier 3 benchmark API key. Leave blank if you only want to run
# curated locally.
GNEWS_API_KEY=
GNEWS_MAX_ARTICLES_PER_PAGE=10
GNEWS_MAX_PAGES_PER_QUERY=3
FILESYSTEM_PATH_BUDGET=240

# ── Web scraping ──────────────────────────────────────────────────────────────
SCRAPE_REQUEST_TIMEOUT_SECONDS=30
SCRAPE_RETRY_MAX_ATTEMPTS=3
SCRAPE_RETRY_BACKOFF_SECONDS=5

# ── NLP models ────────────────────────────────────────────────────────────────
# Pin to specific model names for reproducibility.
# To pin to a specific git revision on HuggingFace Hub, append @<commit-sha>.
NER_MODEL_NAME=Jean-Baptiste/camembert-ner
SENTIMENT_MODEL_NAME=cmarkea/distilcamembert-base-sentiment
NLI_MODEL_NAME=BaptisteDoyen/camembert-base-xnli
EMBEDDING_MODEL_NAME=dangvantuan/sentence-camembert-base

# ── NLP inference ─────────────────────────────────────────────────────────────
# Reduce NLP_BATCH_SIZE if you encounter GPU out-of-memory (OOM) errors.
NLP_BATCH_SIZE=32
NLP_MAX_TOKEN_LENGTH=512

# ── Data quality (DQ) thresholds ─────────────────────────────────────────────
# Articles with fewer characters than this are quarantined (likely stubs).
DQ_MIN_ARTICLE_TEXT_LENGTH=100

# Silver writes fail if more than this fraction of key-column values are NULL.
DQ_MAX_NULL_RATE=0.05
